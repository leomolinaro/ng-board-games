{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "app": {
      "projectType": "application",
      "root": "projects/app",
      "sourceRoot": "projects/app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/projects/app",
            "index": "projects/app/src/index.html",
            "browser": "projects/app/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/app/src/styles",
                "projects/barony/src/styles",
                "projects/britannia/src/styles",
                "projects/wotr/src/styles",
                "projects/commons/src/styles"
              ]
            },
            "assets": [
              "projects/app/src/favicon.ico",
              "projects/app/src/assets",
              {
                "glob": "**/*",
                "input": "node_modules/@taiga-ui/icons/src",
                "output": "assets/taiga-ui/icons"
              },
              {
                "input": "projects/agot/src/assets",
                "glob": "**/*",
                "output": "/assets"
              },
              {
                "input": "projects/barony/src/assets",
                "glob": "**/*",
                "output": "/assets"
              },
              {
                "input": "projects/britannia/src/assets",
                "glob": "**/*",
                "output": "/assets"
              },
              {
                "input": "projects/commons/src/assets",
                "glob": "**/*",
                "output": "/assets"
              },
              {
                "input": "projects/talisman/src/assets",
                "glob": "**/*",
                "output": "/assets"
              },
              {
                "input": "projects/wotr/src/assets",
                "glob": "**/*",
                "output": "/assets"
              }
            ],
            "styles": [
              "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "projects/app/src/styles.scss",
              "@taiga-ui/styles/taiga-ui-theme.less",
              "@taiga-ui/styles/taiga-ui-fonts.less",
              "@taiga-ui/addon-mobile/styles/taiga-ui-mobile.less"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "10mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "app:build:production"
            },
            "development": {
              "buildTarget": "app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "app:build"
          }
        }
      }
    },
    "agot": {
      "projectType": "library",
      "root": "projects/agot",
      "sourceRoot": "projects/agot/src",
      "prefix": "agot",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/agot/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/agot/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/agot/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "barony": {
      "projectType": "library",
      "root": "projects/barony",
      "sourceRoot": "projects/barony/src",
      "prefix": "barony",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/barony/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/barony/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/barony/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "britannia": {
      "projectType": "library",
      "root": "projects/britannia",
      "sourceRoot": "projects/britannia/src",
      "prefix": "britannia",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/britannia/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/britannia/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/britannia/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "commons": {
      "projectType": "library",
      "root": "projects/commons",
      "sourceRoot": "projects/commons/src",
      "prefix": "commons",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/commons/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/commons/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/commons/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "talisman": {
      "projectType": "library",
      "root": "projects/talisman",
      "sourceRoot": "projects/talisman/src",
      "prefix": "talisman",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/talisman/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/talisman/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/talisman/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "wotr": {
      "projectType": "library",
      "root": "projects/wotr",
      "sourceRoot": "projects/wotr/src",
      "prefix": "wotr",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/wotr/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/wotr/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/wotr/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  },
  "defaultProject": "app",
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
